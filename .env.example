# Nous deployment configuration
# Copy to .env and fill in your values

# Domain for Traefik routing (FleetDeck sets this automatically)
NOUS_DOMAIN=nous.yourdomain.com

# LLM model (default: qwen2.5:1.5b — best balance of quality and speed)
NOUS_MODEL=qwen2.5:1.5b

# Ollama server URL (use service name when running with docker-compose)
NOUS_OLLAMA_HOST=http://ollama:11434

# API key for HTTP server authentication (generate with: openssl rand -hex 32)
NOUS_API_KEY=

# Telegram bot token (from @BotFather, optional)
NOUS_TELEGRAM_TOKEN=
