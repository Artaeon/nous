# Nous deployment configuration
# Copy to .env and fill in your values

# Your domain (used by Traefik for HTTPS)
DOMAIN=example.com

# LLM model (default: qwen3:4b — best balance of quality and speed)
NOUS_MODEL=qwen3:4b

# API key for HTTP server authentication (leave empty for local-only)
NOUS_API_KEY=your-secret-api-key-here

# Telegram bot token (from @BotFather)
NOUS_TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
